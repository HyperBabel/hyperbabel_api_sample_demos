# HyperBabel API Configuration
# Copy this file to .env and fill in your values

# HyperBabel API Base URL
VITE_HB_API_URL=https://api.hyperbabel.com/api/v1

# Your HyperBabel API Key
# Get this from the HyperBabel Console → Dashboard → API Keys
VITE_HB_API_KEY=your_api_key_here

# ── Real-Time & RTC ───────────────────────────────────────────────────────
# No additional keys are needed for real-time messaging or video/streaming.
# All session credentials are issued by the HyperBabel Token APIs:
#   - Real-time channel : POST /rtm/token        (returns signed token request)
#   - Video / Stream RTC: POST /rtm/rtc/token    (returns RTC token + app config)
# These endpoints use your VITE_HB_API_KEY for authentication.

# ── Web Push Notifications (Optional) ─────────────────────────────────────
# Required only if you want browser push notifications (🔔) via HyperBabel.
# 1. Create a Firebase project at https://console.firebase.google.com
# 2. Enable Cloud Messaging (FCM) in Firebase Console
# 3. Copy the values below from your Firebase project settings
# The demo registers the FCM token with HyperBabel's Push API automatically.
#
# Leave blank to disable push notifications (all other features still work).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Generate a VAPID key in Firebase Console → Cloud Messaging → Web Push Certificates
VITE_FIREBASE_VAPID_KEY=


