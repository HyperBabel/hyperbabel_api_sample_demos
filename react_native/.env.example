# HyperBabel React Native Demo — Environment Variables
# Copy this file to .env and fill in your values.

# ── HyperBabel API ──────────────────────────────────────────────────────────
EXPO_PUBLIC_HB_API_URL=https://api.hyperbabel.com/api/v1

# Your HyperBabel API Key
# Get it from: HyperBabel Console → Dashboard → API Keys
EXPO_PUBLIC_HB_API_KEY=your_api_key_here

# ── Real-Time & RTC ──────────────────────────────────────────────────────────
# No additional keys needed for real-time messaging or video/streaming.
# All session credentials are issued by the HyperBabel Token APIs:
#   - Real-time channel : POST /rtm/token        (returns signed token request)
#   - Video / Stream RTC: POST /rtm/rtc/token    (returns RTC token + app config)
# These endpoints use EXPO_PUBLIC_HB_API_KEY for authentication.

# ── Push Notifications (Optional) ───────────────────────────────────────────
# Required only if you want push notifications via Firebase Cloud Messaging.
# Steps:
#   1. Create a Firebase project at https://console.firebase.google.com
#   2. Enable Cloud Messaging (FCM) in Firebase Console
#   3. Download GoogleService-Info.plist (iOS) and google-services.json (Android)
#      and place them in the project root directory.
#
# Leave blank to disable push notifications (all other features still work).
#
# Note: Firebase config is handled via native files (GoogleService-Info.plist,
# google-services.json) — no JavaScript env vars needed for the native SDK.
# The following is only used if you integrate Firebase JS SDK (not recommended
# for React Native — use @react-native-firebase instead).
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
